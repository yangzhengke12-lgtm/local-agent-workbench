# Local Agent Workbench environment example
#
# Copy this file to .env and fill only the providers you actually use.
# The desktop app can start without keys, but real LLM tasks need at least
# one configured provider.

# Default Anthropic-compatible provider used by DeepSeek routing.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Optional OpenAI-compatible providers.
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# Optional GPT/OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=
