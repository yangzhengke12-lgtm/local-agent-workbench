            "content": "#!/usr/bin/env node\n/**\n * hello.js — 一个简单的 Hello World 程序（Node.js 版）。\n *\n * 使用现代 ES6+ 语法，通过箭头函数封装问候逻辑，\n * 并将消息打印到标准输出。\n */\n\n/**\n * 程序入口函数。向控制台打印 \"Hello, World!\"。\n * @returns {void}\n */\nconst main = () => {\n  console.log(\"Hello, World!\");\n};\n\n// 仅在直接运行该脚本时执行 main 函数\nif (require.main === module) {\n  main();\n}\n"
