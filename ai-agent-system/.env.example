# Local Agent Workbench environment example
#
# Copy this file to .env and fill only the providers you actually use.
# The desktop app can start without keys, but real LLM tasks need at least
# one configured provider.

# Default Anthropic-compatible provider used by DeepSeek routing.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Optional OpenAI-compatible providers.
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# Optional GPT/OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional business connector target.
# When empty, internal_api_request uses examples/internal_api_demo.json.
INTERNAL_API_BASE_URL=
INTERNAL_API_TOKEN=

# Optional Feishu/Lark custom bot connector.
# Create a group custom bot, copy its webhook here, and keep the secret local.
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Optional Feishu/Lark app connector for bidirectional chat.
# Use these when enabling event subscriptions and replying to the source chat.
FEISHU_EVENT_VERIFICATION_TOKEN=
FEISHU_EVENT_ENCRYPT_KEY=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DEFAULT_TASK_TYPE=manager_task
FEISHU_DEFAULT_WORKER=Elena
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
